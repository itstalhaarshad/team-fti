# ---- LLM provider config (read by core/llm.py) ----
# Which vendor sits behind the wrapper. Default = gemini.
# Swappable later to: claude | openai  (wrapper handles the rest)
LLM_PROVIDER=gemini

# Model id. Nothing in the app hard-codes this.
#   gemini  -> gemini-2.5-flash   (default: vision + JSON, free tier)
#   claude  -> claude-sonnet-4-6
#   openai  -> gpt-4o
LLM_MODEL=gemini-2.5-flash

# API keys — fill the one matching LLM_PROVIDER. NEVER commit the real .env.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: cache the rubric as Gemini cached content (nice-to-have).
ENABLE_RUBRIC_CACHE=false

# ---- Storage backend ----
# local    = file-backed store under data/batches/ (default; no cloud needed)
# firestore = Firebase Firestore, data scoped per signed-in teacher (uid)
STORAGE_BACKEND=local

# ---- Firebase (email signup/login + Firestore) ----
# Web API key from Firebase console > Project settings > General (enables email auth).
# Leave blank to run with NO sign-in gate (single-user local mode).
FIREBASE_WEB_API_KEY=
# Path to the service-account JSON (Firebase console > Project settings > Service accounts).
# NEVER commit this file. Required when STORAGE_BACKEND=firestore.
FIREBASE_SERVICE_ACCOUNT=firebase-service-account.json
