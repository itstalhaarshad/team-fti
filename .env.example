# ---- LLM provider config (read by core/llm.py) ----
# Which vendor sits behind the wrapper. Default = gemini.
# Swappable later to: claude | openai  (wrapper handles the rest)
LLM_PROVIDER=gemini

# Model id. Nothing in the app hard-codes this.
#   gemini  -> gemini-2.5-flash   (default: vision + JSON, free tier)
#   claude  -> claude-sonnet-4-6
#   openai  -> gpt-4o
LLM_MODEL=gemini-2.5-flash

# API keys — fill the one matching LLM_PROVIDER. NEVER commit the real .env.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: cache the rubric as Gemini cached content (nice-to-have).
ENABLE_RUBRIC_CACHE=false
